# EasyJob — Environment Variables
# Copy this file to .env.local and fill in your credentials

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for all AI generation features (JD analysis, code gen, resume realignment, outreach)
OPENAI_API_KEY=sk-...

# ── Supabase ──────────────────────────────────────────────────────────────────
# Required for persistent storage of application packages
# Get these from: https://supabase.com/dashboard/project/[your-project]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Vercel Deployment API ─────────────────────────────────────────────────────
# Required for automated proof-of-work project deployment
# Generate at: https://vercel.com/account/tokens
VERCEL_API_TOKEN=your-vercel-token-here
# Optional: Vercel team ID (only needed for team accounts)
VERCEL_TEAM_ID=

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Notes ─────────────────────────────────────────────────────────────────────
# Without OPENAI_API_KEY: All AI generation will fail with an error
# Without Supabase: App runs in local mode (no persistence, no status polling)  
# Without VERCEL_API_TOKEN: Deployed project URL uses sandbox mock URL instead of live Vercel URL
